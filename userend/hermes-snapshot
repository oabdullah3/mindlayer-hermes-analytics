#!/usr/bin/env bash
# -*- mode: shell-script; -*-
#
# hermes-snapshot — Agent-invocable slash command for Hermes Analytics.
#
# Usage:
#   hermes-snapshot            Collect analytics and show inline summary
#   hermes-snapshot dashboard  Same + print dashboard URL
#
# Sources ~/.hermes-analytics.conf for HERMES_ANALYTICS_USER and
# HERMES_ANALYTICS_REMOTE.  If the config file is missing, exits with an
# error telling the user to run userend/install.sh first.
set -euo pipefail

# ────────────────────────────────────────────────────────────────────────
# Locate the repo root (directory containing this script)
# ────────────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

# ────────────────────────────────────────────────────────────────────────
# Parse subcommand
# ────────────────────────────────────────────────────────────────────────
DASHBOARD=false
if [[ "${1:-}" == "dashboard" ]]; then
    DASHBOARD=true
fi

# ────────────────────────────────────────────────────────────────────────
# Config
# ────────────────────────────────────────────────────────────────────────
CONFIG_FILE="$HOME/.hermes-analytics.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Run userend/install.sh first to configure Hermes Analytics"
    exit 1
fi

# shellcheck disable=SC1090
source "$CONFIG_FILE"

# ────────────────────────────────────────────────────────────────────────
# Run the collector
# ────────────────────────────────────────────────────────────────────────
COLLECTOR_OUTPUT=$(mktemp /tmp/hermes-snapshot-output.XXXXXX)
COLLECTOR_EXIT=0

cd "$REPO_ROOT"
python3 userend/collector.py > "$COLLECTOR_OUTPUT" 2>&1 || COLLECTOR_EXIT=$?

if [[ $COLLECTOR_EXIT -ne 0 ]]; then
    echo "❌ Collection failed:"
    cat "$COLLECTOR_OUTPUT"
    rm -f "$COLLECTOR_OUTPUT"
    exit $COLLECTOR_EXIT
fi

# ────────────────────────────────────────────────────────────────────────
# Parse collector output for counts
# ────────────────────────────────────────────────────────────────────────
# Output format: "SUCCESS: Snapshot written to <path>"
#                "  N sessions, N skill loads, N tool types"

SESSION_COUNT=$(grep -oP '\d+(?= sessions)' "$COLLECTOR_OUTPUT" || echo "0")
SKILL_COUNT=$(grep -oP '\d+(?= skill loads)' "$COLLECTOR_OUTPUT" || echo "0")
TOOL_COUNT=$(grep -oP '\d+(?= tool types)' "$COLLECTOR_OUTPUT" || echo "0")

# Read the snapshot to get richer stats
SNAPSHOT_FILE="$REPO_ROOT/snapshot_latest.json"

SHELL_TOTAL=0
SHELL_FAILED=0
ERROR_TOTAL=0
SKILL_NAMES=""
TOOL_NAMES=""
PUSHED=false
REMOTE_URL="${HERMES_ANALYTICS_REMOTE:-}"

if [[ -f "$SNAPSHOT_FILE" ]]; then
    # Count shell commands and failures
    SHELL_STATS=$(python3 -c "
import json
with open('$SNAPSHOT_FILE') as f:
    snap = json.load(f)
sessions = snap.get('sessions', [])
shell_total = sum(len(s.get('shell_commands', [])) for s in sessions)
shell_failed = sum(sum(1 for c in s.get('shell_commands', []) if c.get('failed_at')) for s in sessions)
error_total = sum(len(s.get('errors', [])) for s in sessions)
# Top skill
all_skills = []
for s in sessions:
    for sk in s.get('skills_loaded', []):
        all_skills.append(sk.get('skill_name', 'unknown'))
from collections import Counter
skill_counts = Counter(all_skills)
top_skill = skill_counts.most_common(1)
top_skill_str = f'{top_skill[0][0]} ×{top_skill[0][1]}' if top_skill else 'none'
# Unique tools
all_tools = set()
for s in sessions:
    for t in s.get('tool_calls', []):
        all_tools.add(t.get('tool_name', ''))
print(f'{shell_total}|{shell_failed}|{error_total}|{top_skill_str}|{len(all_tools)}')
" 2>/dev/null)
    IFS='|' read -r SHELL_TOTAL SHELL_FAILED ERROR_TOTAL TOP_SKILL UNIQUE_TOOLS <<< "$SHELL_STATS"
else
    TOP_SKILL="none"
    UNIQUE_TOOLS="$TOOL_COUNT"
fi

# Determine if we pushed to remote
if [[ -n "$REMOTE_URL" ]]; then
    PUSHED=true
fi

# ────────────────────────────────────────────────────────────────────────
# Inline summary
# ────────────────────────────────────────────────────────────────────────
echo ""
echo "📊 Hermes Analytics Snapshot"
echo "   Sessions: ${SESSION_COUNT:-0}"
echo "   Skills loaded: ${SKILL_COUNT:-0} (top: ${TOP_SKILL:-none})"
echo "   Tool calls: ${TOOL_COUNT:-0} across ${UNIQUE_TOOLS:-0} tools"
echo "   Shell commands: ${SHELL_TOTAL:-0} (${SHELL_FAILED:-0} failed)"
echo "   Errors: ${ERROR_TOTAL:-0}"

if [[ "$PUSHED" == "true" ]]; then
    echo "   Pushed to: ${REMOTE_URL} ✅"
else
    echo "   Saved locally"
fi

if [[ "$DASHBOARD" == "true" ]]; then
    DASHBOARD_URL="${REMOTE_URL:-http://localhost:3000}"
    echo "📊 Dashboard: ${DASHBOARD_URL}"
fi

rm -f "$COLLECTOR_OUTPUT"
